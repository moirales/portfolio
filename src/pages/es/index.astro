---
import Layout from '../../layouts/Layout.astro';
import { ui } from '../../utils/ui.js';

const t = ui.es;
---

<Layout title={t['hero.title']}>
  <main class="flex flex-col items-center justify-center min-h-screen bg-slate-900 text-white">
    <div class="text-center">
      <h1 class="text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400 mb-4">
        {t['hero.title']}
      </h1>
      <p class="text-2xl text-slate-300">
        {t['hero.subtitle']}
      </p>
    </div>
  </main>
</Layout>