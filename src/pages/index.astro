---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MM | Data & AI Engineer">
  <main class="min-h-screen flex items-center justify-center bg-[#0b1120] px-6 py-12 relative overflow-hidden">
    
    <div class="absolute top-0 -left-4 w-72 h-72 bg-orange-600 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob"></div>
    <div class="absolute bottom-0 -right-4 w-72 h-72 bg-blue-600 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-2000"></div>

    <div class="max-w-4xl w-full z-10">
      <header class="text-center mb-16">
        <h2 class="text-orange-500 font-mono text-sm tracking-[0.3em] uppercase mb-4">Systems Engineer</h2>
        <h1 class="text-6xl font-extrabold text-white tracking-tight mb-4">
          Moises Morales
        </h1>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto leading-relaxed">
          Specializing in transforming raw data into strategic assets. 
          Expertise in advanced data processing, visual intelligence, and local AI model deployment.
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <a href="/en/analytics" class="group relative bg-slate-900/50 border border-slate-700 p-8 rounded-3xl hover:border-orange-500/50 transition-all duration-300 shadow-xl">
          <div class="mb-5 p-3 bg-orange-500/10 rounded-2xl w-fit group-hover:bg-orange-500/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2 italic tracking-tight">Analytics Project</h3>
          <p class="text-slate-400 text-xs leading-relaxed">
            End-to-end data processing and visual storytelling using Python, Jupyter, and Power BI across multiple business sectors.
          </p>
          <div class="mt-6 flex items-center text-orange-500 text-[10px] font-bold uppercase tracking-wider group-hover:gap-2 transition-all">
            View Analytics <span>→</span>
          </div>
        </a>

        <a href="/en/ai-menu" class="group relative bg-slate-900/50 border border-slate-700 p-8 rounded-3xl hover:border-blue-500/50 transition-all duration-300 shadow-xl">
          <div class="mb-5 p-3 bg-blue-500/10 rounded-2xl w-fit group-hover:bg-blue-500/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2 italic tracking-tight">AI Assistant</h3>
          <p class="text-slate-400 text-xs leading-relaxed whitespace-pre-line">
            Facilitates chat management for business and provides latest insights based on our specialized data analysis.
          </p>
          <div class="mt-6 flex items-center text-blue-500 text-[10px] font-bold uppercase tracking-wider group-hover:gap-2 transition-all">
            Explore Assistant <span>→</span>
          </div>
        </a>

        <a href="/en/cv" class="group relative bg-slate-900/50 border border-slate-700 p-8 rounded-3xl hover:border-emerald-500/50 transition-all duration-300 shadow-xl">
          <div class="mb-5 p-3 bg-emerald-500/10 rounded-2xl w-fit group-hover:bg-emerald-500/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2 italic tracking-tight">My Profile</h3>
          <p class="text-slate-400 text-xs leading-relaxed whitespace-pre-line">
            Professional trajectory, including academic background, technical stack, and industrial work experience.
          </p>
          <div class="mt-6 flex items-center text-emerald-500 text-[10px] font-bold uppercase tracking-wider group-hover:gap-2 transition-all">
            See Résumé <span>→</span>
          </div>
        </a>

      </div>

      <footer class="mt-20 text-center border-t border-slate-800 pt-8">
        <p class="text-slate-500 text-[10px] uppercase tracking-widest font-mono">
          Systems Engineering Portfolio | Moises Morales | 2026
        </p>
      </footer>
    </div>
  </main>
</Layout>

<style>
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob {
    animation: blob 7s infinite;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
</style>