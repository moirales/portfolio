---
import Layout from '../../layouts/Layout.astro';
import insights from '../../data/pizzai_insights.json';

// ModelFile content - Cleanly formatted
const modelFileCode = `# ModelFile Configuration
FROM llama3
PARAMETER temperature 0.7
PARAMETER repeat_penalty 1.1
PARAMETER context_length 2048

SYSTEM """
You are PizzAI Bot, a professional
Italian Data Consultant. Use provided
JSON context to analyze performance.
Tone: Expert, helpful, with a touch
of Italian flair.
"""`;
---

<Layout title="PizzAI">
  <main class="max-w-6xl mx-auto px-6 py-12 text-white font-sans">
    
    <header class="mb-12 border-l-4 border-orange-600 pl-6 flex justify-between items-end">
      <div>
        <h1 class="text-5xl font-extrabold tracking-tight mb-2">PizzAI Bot</h1>
        <p class="text-slate-400 text-sm uppercase tracking-[0.2em] font-mono">Llama 3 Powered • Restaurant Analytics Case Study</p>
      </div>
      <div class="text-right hidden md:block">
        <span class="text-[10px] text-slate-500 block uppercase font-bold">Analysis Engine</span>
        <span class="text-orange-500 font-mono text-sm">v1.0.4-stable</span>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      
      <div class="lg:col-span-7 flex flex-col gap-6">
        <div class="bg-slate-900 border border-slate-700 rounded-3xl overflow-hidden shadow-2xl flex flex-col">
          
          <div class="bg-slate-800/80 p-5 border-b border-slate-700 flex items-center justify-between backdrop-blur-sm">
            <div class="flex items-center gap-4">
              <div class="relative">
                <img 
                  src="https://cdn-icons-png.flaticon.com/512/3595/3595455.png" 
                  alt="PizzaAI Profile" 
                  class="w-12 h-12 rounded-full border-2 border-orange-500 bg-slate-700 p-1"
                />
                <span class="absolute bottom-0 right-0 w-3 h-3 bg-emerald-500 border-2 border-slate-800 rounded-full animate-pulse"></span>
              </div>
              <div>
                <h2 class="text-lg font-bold text-white leading-tight">PizzAI Bot</h2>
                <p class="text-xs text-slate-400">Active Digital Chef & Consultant</p>
              </div>
            </div>
            <div class="text-[10px] text-slate-500 font-mono hidden sm:block">
               ID: LLM-EXPERT-99
            </div>
          </div>

          <div id="chat-box" class="h-[400px] overflow-y-auto p-6 space-y-6 bg-[#0b1120] scroll-smooth">
            <div class="flex gap-4">
              <img src="https://cdn-icons-png.flaticon.com/512/3595/3595455.png" class="w-8 h-8 rounded-full opacity-50 self-start" />
              <div class="flex flex-col gap-1 max-w-[85%]">
                <span class="text-[9px] text-slate-500 uppercase font-bold">PizzAI Bot</span>
                <div class="bg-slate-800 p-4 rounded-2xl rounded-tl-none text-sm border border-slate-700 text-slate-200 leading-relaxed">
                  Benvenuto! I am your consultant. I've finished syncing the latest inventory and sales data. How shall we grow the business today? 🤌
                </div>
              </div>
            </div>
          </div>

          <div class="px-4 py-3 bg-slate-900/50 border-t border-slate-800 flex gap-2 overflow-x-auto no-scrollbar">
            {['Best Seller', 'Inventory Alerts', 'Growth Strategy'].map((label) => (
              <button class="quick-btn text-[10px] bg-slate-800 hover:bg-orange-600 px-4 py-2 rounded-full border border-slate-700 transition-all text-slate-300 font-medium whitespace-nowrap">
                {label}
              </button>
            ))}
          </div>

          <div class="p-4 bg-slate-950 flex gap-3">
            <input id="user-input" type="text" placeholder="Message PizzAI Bot..." 
              class="flex-grow bg-slate-900 border border-slate-800 rounded-2xl px-5 py-4 text-sm focus:outline-none focus:border-orange-500 transition-all text-white placeholder:text-slate-600"/>
            <button id="send-btn" class="bg-orange-600 px-6 py-4 rounded-2xl hover:bg-orange-500 transition-all shadow-lg shadow-orange-900/20 active:scale-95">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z" /></svg>
            </button>
          </div>
        </div>
      </div>

      <div class="lg:col-span-5 flex flex-col gap-6">
        
        <div class="bg-slate-900 border border-slate-700 rounded-3xl p-6 shadow-xl relative overflow-hidden group">
          <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-30 transition-opacity">
            <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/></svg>
          </div>
          <h3 class="text-xs font-bold text-orange-500 mb-4 flex items-center gap-2 uppercase tracking-widest">
            <span class="w-2 h-2 bg-orange-500 rounded-full"></span>
            ModelFile Config
          </h3>
          <div class="bg-black/40 rounded-xl p-5 border border-white/5 shadow-inner">
            <pre class="font-mono text-[12px] text-slate-300 leading-6 overflow-x-auto whitespace-pre-wrap"><code>{modelFileCode}</code></pre>
          </div>
        </div>

        <div class="bg-slate-900 border border-slate-700 rounded-3xl p-6 shadow-xl">
          <h3 class="text-xs font-bold text-orange-500 mb-6 uppercase tracking-widest flex items-center gap-2">
            <span class="w-2 h-2 bg-orange-500 rounded-full"></span>
            Architecture Highlights
          </h3>
          <div class="space-y-6">
            {[
              { title: 'Local Llama 3', desc: 'Self-hosted via Ollama for maximum data privacy.' },
              { title: 'RAG Pipeline', desc: 'Jupyter-to-JSON bridge for context-aware responses.' },
              { title: 'System Guardrails', desc: 'Hardcoded logic to eliminate LLM hallucinations.' }
            ].map(item => (
              <div class="flex gap-4">
                <div class="h-8 w-1 bg-orange-600/30 rounded-full mt-1"></div>
                <div>
                  <h4 class="text-sm font-bold text-white">{item.title}</h4>
                  <p class="text-[11px] text-slate-400 leading-relaxed mt-1">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </main>
</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script is:inline define:vars={{ insights }}>
  // Logic same as previous version but with improved message template
  const chatBox = document.querySelector('#chat-box');
  const userInput = document.querySelector('#user-input');
  const sendBtn = document.querySelector('#send-btn');
  const quickBtns = document.querySelectorAll('.quick-btn');
  let chatContext = null;

  async function handleMessage(text) {
    if (!text || text.trim() === "") return;

    // User Message Template
    chatBox.innerHTML += `
      <div class="flex flex-col items-end gap-1">
        <span class="text-[9px] text-slate-500 mr-2 uppercase font-mono">User_Session</span>
        <div class="bg-orange-600 p-3 rounded-2xl rounded-tr-none text-sm shadow-md max-w-[85%] text-white">
          ${text}
        </div>
      </div>
    `;
    userInput.value = '';
    chatBox.scrollTop = chatBox.scrollHeight;

    const thinkingId = 'thinking-' + Date.now();
    chatBox.innerHTML += `
      <div id="${thinkingId}" class="flex gap-4">
        <div class="w-8 h-8 rounded-full bg-slate-800 animate-pulse"></div>
        <div class="flex flex-col gap-1">
          <span class="text-[9px] text-slate-500 uppercase font-mono tracking-tighter">PizzAI_Engine</span>
          <div class="text-xs text-slate-500 italic">Preparing your answer...</div>
        </div>
      </div>
    `;
    chatBox.scrollTop = chatBox.scrollHeight;

    try {
      const systemContext = `
        STRICT PERSONA: 
        You are "PizzAI Bot", a passionate pizza lover Data Analyst. 
        Talk like a master Pizzaiolo (energetic, professional).
        
        YOUR REAL DATABASE:
        - BEST SELLER: ${insights.sales_performance.best_seller}
        - REVENUE: ${insights.sales_performance.revenue_total} ${insights.metadata.currency}
        - PEAK TIME: ${insights.sales_performance.peak_hours}
        - BEST DAY: ${insights.sales_performance.most_profitable_day}
        - INVENTORY ALERTS: ${insights.inventory.critical_low.join(', ')}
        - SURPLUS STOCK: ${insights.inventory.surplus.join(', ')}
        - STRATEGIC RECOMMENDATIONS: ${insights.recommendations.join(' | ')}

        STRICT RULES:
        1. Use ONLY the data above. If the user asks for something else, say: "Mamma mia, my oven doesn't have that data slice yet!"
        2. Use 🍕, 📊, and 🤌 emojis.
        3. Never admit you are an AI. You are the Digital Chef.
        4. Be concis, bullet points no longer than 100 letters.
      `;

      const response = await fetch('http://localhost:11434/api/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'llama3',
          prompt: text,
          system: systemContext,
          context: chatContext,
          stream: false
        })
      });

      const data = await response.json();
      chatContext = data.context;
      document.getElementById(thinkingId).remove();

      // Bot Message Template with Image
      chatBox.innerHTML += `
        <div class="flex gap-4">
          <img src="https://cdn-icons-png.flaticon.com/512/3595/3595455.png" class="w-8 h-8 rounded-full border border-orange-500/30" />
          <div class="flex flex-col gap-1 max-w-[85%]">
            <span class="text-[9px] text-slate-500 uppercase font-bold">PizzAI Bot</span>
            <div class="bg-slate-800 p-4 rounded-2xl rounded-tl-none text-sm border border-slate-700 text-slate-100 shadow-sm leading-relaxed">
              ${data.response}
            </div>
          </div>
        </div>
      `;
      
    } catch (e) {
      document.getElementById(thinkingId).innerHTML = `<div class="text-red-400 text-[10px] uppercase font-bold">Connection Refused: Check Ollama</div>`;
    }
    chatBox.scrollTop = chatBox.scrollHeight;
  }

  sendBtn.addEventListener('click', () => handleMessage(userInput.value));
  userInput.addEventListener('keydown', (e) => e.key === 'Enter' && handleMessage(userInput.value));
  quickBtns.forEach(btn => btn.addEventListener('click', () => handleMessage(btn.innerText)));
</script>