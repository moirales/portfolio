---
import Layout from '../../layouts/Layout.astro';
import PizzaiBot from '../../components/PizzaiBot.astro';

const insights = {
  sales_performance: {
    best_seller: "Classic Pizza (32%)",
    revenue_total: "817,860",
    peak_hours: "12:30 PM - 1:45 PM"
  },
  inventory: { critical_low: ["Mushrooms", "Pepperoni"] },
  recommendations: ["Increase staff during 12:00-14:00"]
};

const modelFileCode = `FROM llama3\nPARAMETER temperature 0.7\nSYSTEM "You are PizzAI Bot..."`;
---
<Layout title="PizzAI">
  <main class="max-w-6xl mx-auto px-6 py-12 text-white font-sans">
    
    <nav class="mb-8">
      <a href="/en/ai-menu" class="text-blue-500 text-xs font-mono inline-flex items-center gap-2 hover:text-blue-400 transition-colors group">
    <span class="group-hover:-translate-x-1 transition-transform">←</span> BACK TO HOME
      </a>
    </nav>

    <header class="mb-12 border-l-4 border-orange-600 pl-6">
        <h1 class="text-5xl font-extrabold italic tracking-tight mb-2 text-white">PizzAI Bot</h1>
        <p class="text-slate-400 text-sm uppercase tracking-[0.2em] font-mono">Simulated Web Engine • Case Study</p>
    </header>

    <PizzaiBot insights={insights} modelFileCode={modelFileCode} />
    
  </main>
</Layout>