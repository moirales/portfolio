---
import Layout from '../../layouts/Layout.astro';
import YanisChat from '../../components/YanisChat.astro';

// Datos de negocio para el Case Study (Look similar a PizzAI)
const insights = {
  photography_performance: {
    most_requested: "Wedding Editorial (45%)",
    conversion_rate: "24% from Chat",
    peak_inquiries: "7:00 PM - 10:00 PM"
  },
  knowledge_base: { 
    source_files: ["Pricing_2026.pdf", "Services_Guide.pdf"],
    processing: "RAG + Llama 3 Cloud" 
  },
  recommendations: ["Promote 'Golden Hour' sessions", "Integrate booking calendar"]
};

// Configuración técnica para mostrar en el panel lateral
const modelFileCode = `FROM llama3-70b\nPARAMETER temperature 0.5\nSYSTEM "You are Yanis AI, a boutique photography assistant. Respond with elegance and precision using the provided studio context."`;
---

<Layout title="Yanis AI | Photography Consultant">
  <main class="max-w-6xl mx-auto px-6 py-12 text-white font-sans min-h-screen">
    
    <nav class="mb-8">
      <a href="/en/ai-menu" class="text-blue-500 text-xs font-mono inline-flex items-center gap-2 hover:text-blue-400 transition-colors group">
        <span class="group-hover:-translate-x-1 transition-transform">←</span> BACK TO HOME
      </a>
    </nav>

    <header class="mb-12 border-l-8 border-orange-600 pl-8">
        <h1 class="text-6xl font-black italic tracking-tighter mb-2 text-white uppercase">
            Yanis AI
        </h1>
        <div class="flex items-center gap-4">
            <span class="bg-orange-600 text-black text-[10px] font-bold px-2 py-0.5 rounded">PROD_READY</span>
            <p class="text-slate-500 text-xs uppercase tracking-[0.3em] font-mono">
                TANGERINE PROFESSIONAL PHOTOGRAPHY
            </p>
        </div>
    </header>

    <div class="relative">
        <div class="absolute -top-2 -left-2 w-4 h-4 border-t-2 border-l-2 border-orange-600"></div>
        <div class="absolute -bottom-2 -right-2 w-4 h-4 border-b-2 border-r-2 border-orange-600"></div>
        
        <YanisChat insights={insights} modelFileCode={modelFileCode} />
    </div>

    <footer class="mt-12 pt-6 border-t border-slate-800 flex justify-between items-center text-[10px] font-mono text-slate-600">
        <span>DEPLOYMENT_STATUS: CLOUD_READY</span>
        <span>ENGINE: LLAMA-3-PROD</span>
        <span>ENCRYPTION: AES-256</span>
    </footer>
    
  </main>
</Layout>

<style is:global>
  /* Fondo Azul Muy Oscuro (Midnight) para máximo contraste */
  body {
    background-color: #020617; 
    color: white;
    -webkit-font-smoothing: antialiased;
  }

  /* Gradiente sutil de fondo */
  body::before {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 5% 5%, rgba(249, 115, 22, 0.08) 0%, transparent 40%);
    pointer-events: none;
    z-index: -1;
  }

  /* Personalización de la barra de desplazamiento */
  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: #020617;
  }
  ::-webkit-scrollbar-thumb {
    background: #1e293b;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #f97316;
  }
</style>