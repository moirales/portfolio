---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Analytics Portfolio">
  <main class="min-h-screen bg-[#0b1120] text-white py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <a href="/en/" class="text-orange-500 text-xs font-mono mb-8 inline-block hover:underline">← BACK TO HOME</a>
      <h1 class="text-4xl font-bold mb-4 italic">Data Analytics Projects</h1>
      <p class="text-slate-400 mb-12">Statistical processing and visual intelligence across different platforms.</p>

      <div class="grid gap-6">
        <div class="bg-slate-900/50 border border-slate-800 p-6 rounded-2xl flex flex-col md:flex-row justify-between items-center gap-6 opacity-80">
          <div>
            <div class="flex items-center gap-3 mb-2">
                <h2 class="text-xl font-bold text-slate-500">Service Customer Analysis</h2>
                <span class="bg-orange-500/10 text-orange-500 text-[8px] font-bold px-2 py-0.5 rounded border border-orange-500/20 animate-pulse">
                    UNDER CONSTRUCTION
                </span>
            </div>
            <p class="text-sm text-slate-500 italic">Advanced Power BI dashboard focusing on user retention. Access restricted during data sanitization.</p>
          </div>
          <button disabled class="bg-slate-800/30 border border-slate-700/50 px-6 py-2 rounded-lg text-xs font-bold text-slate-600 cursor-not-allowed whitespace-nowrap">
            DASHBOARD
          </button>
        </div>

        <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl flex flex-col md:flex-row justify-between items-center gap-6">
          <div>
            <h2 class="text-xl font-bold text-orange-400 mb-2">Pizza Sales Intelligence (Python)</h2>
            <p class="text-sm text-slate-400">Data cleaning and exploratory analysis (EDA) using Pandas and Jupyter to optimize restaurant operations.</p>
          </div>
          <a href="/en/analytics/pizza-analysis" class="bg-slate-800 px-6 py-2 rounded-lg text-xs font-bold hover:bg-orange-600 transition-all whitespace-nowrap inline-block">
            VIEW REPORT
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>