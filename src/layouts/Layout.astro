---
interface Props {
    title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en" class="bg-slate-950 text-white antialiased">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Yanis AI - Luxury Photography Assistant" />
        <meta name="viewport" content="width=device-width" />
        
		<link rel="icon" type="image/jpeg" href="/favicon.jpeg?v=3" />        
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body class="bg-[#0f172a] text-white min-h-screen"> 
        <slot />
    </body>
</html>