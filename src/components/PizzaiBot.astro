---
// src/components/PizzaiBot.astro
const { insights, modelFileCode } = Astro.props;
---

<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
  <div class="lg:col-span-7 flex flex-col gap-6">
    <div class="bg-slate-900 border border-slate-700 rounded-3xl overflow-hidden shadow-2xl flex flex-col">
      <div class="bg-slate-800/80 p-5 border-b border-slate-700 flex items-center justify-between backdrop-blur-sm">
        <div class="flex items-center gap-4">
          <div class="relative">
            <div class="w-12 h-12 rounded-full border-2 border-orange-500 bg-slate-700 flex items-center justify-center text-2xl">🍕</div>
            <span class="absolute bottom-0 right-0 w-3 h-3 bg-emerald-500 border-2 border-slate-800 rounded-full animate-pulse"></span>
          </div>
          <div>
            <h2 class="text-lg font-bold text-white leading-tight">PizzAI Bot</h2>
            <p class="text-xs text-slate-400">Active Digital Chef & Consultant</p>
          </div>
        </div>
        <div class="text-[10px] text-slate-500 font-mono hidden sm:block">ID: ANALYST-WEB-99</div>
      </div>

      <div id="chat-box" class="h-[400px] overflow-y-auto p-6 space-y-6 bg-[#0b1120] scroll-smooth">
        <div class="flex gap-4">
          <div class="w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center text-xs opacity-50 border border-slate-700">🤌</div>
          <div class="flex flex-col gap-1 max-w-[85%]">
            <span class="text-[9px] text-slate-500 uppercase font-bold">PizzAI Bot</span>
            <div class="bg-slate-800 p-4 rounded-2xl rounded-tl-none text-sm border border-slate-700 text-slate-200 leading-relaxed">
              Benvenuto! I am your consultant. I've finished syncing the latest inventory and sales data. How shall we grow the business today? 🤌
            </div>
          </div>
        </div>
      </div>

      <div class="px-4 py-3 bg-slate-900/50 border-t border-slate-800 flex gap-2 overflow-x-auto no-scrollbar">
        {['Best Seller', 'Inventory Alerts', 'Growth Strategy'].map((label) => (
          <button class="quick-btn text-[10px] bg-slate-800 hover:bg-orange-600 px-4 py-2 rounded-full border border-slate-700 transition-all text-slate-300 font-medium whitespace-nowrap">
            {label}
          </button>
        ))}
      </div>

      <div class="p-4 bg-slate-950 flex gap-3">
        <input id="user-input" type="text" placeholder="Ask about sales, tech, or peaks..." 
          class="flex-grow bg-slate-900 border border-slate-800 rounded-2xl px-5 py-4 text-sm focus:outline-none focus:border-orange-500 text-white"/>
        <button id="send-btn" class="bg-orange-600 px-6 py-4 rounded-2xl hover:bg-orange-500 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z" /></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="lg:col-span-5 flex flex-col gap-6">
    <div class="bg-slate-900 border border-slate-700 rounded-3xl p-6 shadow-xl">
      <h3 class="text-xs font-bold text-orange-500 mb-4 uppercase tracking-widest">ModelFile Config</h3>
      <div class="bg-black/40 rounded-xl p-5 border border-white/5 font-mono text-[11px] text-slate-300 whitespace-pre-wrap">
        {modelFileCode}
      </div>
    </div>

    <div class="bg-slate-900 border border-slate-700 rounded-3xl p-6 shadow-xl">
      <h3 class="text-xs font-bold text-orange-500 mb-6 uppercase tracking-widest">Architecture Highlights</h3>
      <div class="space-y-6">
        {[
          { title: 'Local Llama 3', desc: 'Self-hosted via Ollama for maximum data privacy.' },
          { title: 'RAG Pipeline', desc: 'Jupyter-to-JSON bridge for context-aware responses.' },
          { title: 'System Guardrails', desc: 'Hardcoded logic to eliminate LLM hallucinations.' }
        ].map(item => (
          <div class="flex gap-4">
            <div class="h-8 w-1 bg-orange-600/30 rounded-full mt-1"></div>
            <div>
              <h4 class="text-sm font-bold text-white">{item.title}</h4>
              <p class="text-[11px] text-slate-400 leading-relaxed mt-1">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ insights }}>
  // Aquí va toda la lógica de KNOWLEDGE_BASE y handleMessage que ya teníamos
  const chatBox = document.querySelector('#chat-box');
  const userInput = document.querySelector('#user-input');
  const sendBtn = document.querySelector('#send-btn');
  const quickBtns = document.querySelectorAll('.quick-btn');

  const KNOWLEDGE_BASE = {
    revenue: `📊 Mamma mia! Our revenue: ${insights.sales_performance.revenue_total}. The '${insights.sales_performance.best_seller}' is leading! 🍕`,
    peaks: `⏰ Sales peak: ${insights.sales_performance.peak_hours}. Prepare the staff! 🤌`,
    inventory: `📦 Critical low on: ${insights.inventory.critical_low.join(', ')}. 📊`,
    strategy: `🧠 Recommendation: ${insights.recommendations[0]}. 🤌`,
    default: "Mamma mia, try asking for 'revenue', 'best seller', or 'inventory'. 🍕"
  };

  function addMessage(text, isUser = false) {
    const msg = isUser 
      ? `<div class="flex flex-col items-end gap-1"><span class="text-[9px] text-slate-500 uppercase font-mono">Guest</span><div class="bg-orange-600 p-3 rounded-2xl rounded-tr-none text-sm text-white max-w-[85%] shadow-md">${text}</div></div>`
      : `<div class="flex gap-4"><div class="w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center text-xs border border-orange-500/30">🍕</div><div class="flex flex-col gap-1 max-w-[85%]"><span class="text-[9px] text-slate-500 uppercase font-bold">PizzAI Bot</span><div class="bg-slate-800 p-4 rounded-2xl rounded-tl-none text-sm border border-slate-700 text-slate-100">${text}</div></div></div>`;
    chatBox.innerHTML += msg;
    chatBox.scrollTop = chatBox.scrollHeight;
  }

  function handleMessage(text) {
    if (!text || text.trim() === "") return;
    addMessage(text, true);
    userInput.value = '';

    const thinkingId = 'thinking-' + Date.now();
    chatBox.innerHTML += `<div id="${thinkingId}" class="flex gap-4 animate-pulse"><div class="w-8 h-8 rounded-full bg-slate-800"></div><div class="text-xs text-slate-500 italic self-center">Processing...</div></div>`;
    chatBox.scrollTop = chatBox.scrollHeight;

    setTimeout(() => {
      document.getElementById(thinkingId).remove();
      const lowerText = text.toLowerCase();
      let reply = KNOWLEDGE_BASE.default;
      if (lowerText.includes('revenue')) reply = KNOWLEDGE_BASE.revenue;
      else if (lowerText.includes('peak') || lowerText.includes('seller')) reply = KNOWLEDGE_BASE.peaks;
      else if (lowerText.includes('inventory')) reply = KNOWLEDGE_BASE.inventory;
      else if (lowerText.includes('strategy')) reply = KNOWLEDGE_BASE.strategy;
      addMessage(reply);
    }, 800);
  }

  sendBtn.addEventListener('click', () => handleMessage(userInput.value));
  userInput.addEventListener('keydown', (e) => e.key === 'Enter' && handleMessage(userInput.value));
  quickBtns.forEach(btn => btn.addEventListener('click', () => handleMessage(btn.innerText)));
</script>